SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_KEY=your-staging-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
JWT_SECRET=replace-with-strong-staging-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=your-staging-google-client-id.apps.googleusercontent.com
FIREBASE_PROJECT_ID=your-staging-project-id
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-staging-project-id"}
FIREBASE_SERVICE_ACCOUNT_FILE=
CORS_ORIGINS=https://staging-yesh-mishak.vercel.app,http://localhost:5173,http://127.0.0.1:5173
PUBLIC_APP_URL=https://staging-yesh-mishak.vercel.app
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=replace-with-staging-smtp-password
SMTP_FROM_ADDRESS=no-reply@your-verified-domain.example
SMTP_USE_TLS=true
EMAIL_VERIFICATION_TTL_MINUTES=60
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
