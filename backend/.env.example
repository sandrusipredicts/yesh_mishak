# Existing deployments may keep the Resend API key in SMTP_PASSWORD.
SMTP_PASSWORD=
# Optional forward-compatible alias; takes precedence when both are set.
RESEND_API_KEY=
RESEND_API_URL=https://api.resend.com/emails
EMAIL_FROM_ADDRESS=
EMAIL_VERIFICATION_TTL_MINUTES=60
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# Sentry (E09-01). Optional -- absent SENTRY_DSN disables reporting safely.
# SENTRY_ENVIRONMENT must be set explicitly for any deployed environment
# (development/branch-build/production); unset defaults to "local", which
# never reports unless SENTRY_ENABLED=true.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_ENABLED=
