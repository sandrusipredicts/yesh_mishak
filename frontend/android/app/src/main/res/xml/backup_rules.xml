<?xml version="1.0" encoding="utf-8"?>
<!--
  ISSUE-796: App state is server-authoritative. Exclude every supported app
  data domain from legacy Auto Backup so WebView data and encrypted secure
  storage residue cannot be restored after reinstall or device migration.
-->
<full-backup-content>
    <exclude domain="root" path="." />
    <exclude domain="file" path="." />
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="external" path="." />
    <exclude domain="device_root" path="." />
    <exclude domain="device_file" path="." />
    <exclude domain="device_database" path="." />
    <exclude domain="device_sharedpref" path="." />
</full-backup-content>
