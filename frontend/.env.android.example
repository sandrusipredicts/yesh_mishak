# Environment variables for Android (Capacitor) debug/validation builds.
#
# Copy this file to .env.android (git-ignored, never commit it) and fill in
# real values, then build with:
#   npm run build:android
#   npx cap sync android
#
# Why this file exists:
# The Capacitor Android WebView loads the app at https://localhost (an
# HTTPS origin) in every build variant, including debug. VITE_API_URL here
# MUST therefore be an HTTPS backend. A plain http:// address - including a
# developer machine's LAN IP - will be blocked by the WebView's Mixed
# Content policy regardless of backend CORS configuration, and must never
# be committed here. See docs/android-api-configuration.md for details.

VITE_API_URL=https://yesh-mishak-api-staging.railway.app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
