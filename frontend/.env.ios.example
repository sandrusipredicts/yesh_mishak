# Environment variables for iOS (Capacitor) debug/validation builds.
#
# Copy this file to .env.ios (git-ignored, never commit it) and fill in
# real values, then build with:
#   npm run build:ios
#   npx cap sync ios
#
# Why this file exists:
# The Capacitor iOS WebView loads the app at https://localhost (an HTTPS
# origin) in every build variant, including debug - the same as Android.
# VITE_API_URL here MUST therefore be an HTTPS backend. A plain http://
# address will be blocked by the WebView's Mixed Content policy regardless
# of backend CORS configuration, and must never be committed here. See
# docs/android-api-configuration.md for the equivalent Android reasoning
# (identical mechanism applies to iOS) and docs/ios-startup-flow-validation.md
# for iOS-specific evidence.
#
# VITE_API_URL below is the same real, permanent, live production backend
# already confirmed reachable and confirmed to allow the https://localhost
# origin via CORS (see docs/android-api-configuration.md, ISSUE-207). There
# is currently no separately-deployed staging backend live. Prefer a
# dedicated staging backend for routine iOS development once one exists;
# until then, be mindful that this target is production and avoid creating
# or submitting throwaway test data (e.g. field/game submissions) against it.

VITE_API_URL=https://yeshmishak-production.up.railway.app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
