{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prebuild:android:web": "npm run android:google-client-id:validate",
    "build:android:web": "vite build --mode android",
    "build:android:sync": "npx cap sync android",
    "build:android:verify": "node scripts/verify-android-build.mjs",
    "prepare:android:local-release": "node scripts/build-android-release.mjs",
    "prepare:android:official-release": "node scripts/build-android-release.mjs --official",
    "build:ios": "vite build --mode ios",
    "android:google-client-id:validate": "node scripts/validate-android-google-client-id.mjs",
    "android:google-services": "node scripts/materialize-google-services.mjs",
    "android:google-services:validate": "node scripts/materialize-google-services.mjs --validate-file android/app/google-services.json",
    "android:version:validate": "node scripts/validate-android-version.mjs",
    "lint": "eslint .",
    "test:notification-sync": "node --test tests/notification-sync.test.js",
    "test:android-google-services": "node --test scripts/materialize-google-services.test.mjs",
    "test:android-version": "node --test scripts/validate-android-version.test.mjs",
    "test:monitoring": "node --test tests/monitoring-config.test.js tests/monitoring-redaction.test.js tests/monitoring-filters.test.js tests/monitoring-client.test.js",
    "test:analytics": "node --test tests/analytics-queue.test.js tests/analytics-client.test.js",
    "test:auth-interceptor": "node --test tests/auth-interceptor.test.js",
    "test:errors": "node --test tests/errors.test.js",
    "postinstall": "patch-package",
    "test:e2e": "playwright test",
    "test:staging-smoke": "playwright test --config playwright.staging.config.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/app-launcher": "^8.0.0",
    "@capacitor/camera": "^8.2.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.0",
    "@capgo/capacitor-social-login": "8.3.33",
    "@ebarooni/capacitor-calendar": "^8.2.0",
    "@sentry/capacitor": "^4.2.0",
    "@sentry/react": "10.60.0",
    "axios": "^1.17.0",
    "firebase": "^12.15.0",
    "i18next": "^26.3.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "patch-package": "^8.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  }
}
