VITE_API_URL=http://localhost:8000

# Google OAuth Web application client ID. It must exactly match the backend
# GOOGLE_CLIENT_ID audience. Never use an Android OAuth client ID here.
# For Android builds, also register an Android OAuth client for every
# application package/signing SHA-1 pair used to install the app.
VITE_GOOGLE_CLIENT_ID=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
